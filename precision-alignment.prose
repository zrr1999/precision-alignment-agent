# Precision Alignment Agent - Comprehensive Kernel Alignment System
# Systematically aligns Paddle kernels with PyTorch precision through intelligent analysis and iterative fixes

# Input configuration
input api_name: "The Paddle API that needs precision alignment (e.g., 'paddle.nn.functional.softmax')"
input paddle_path: "Path to Paddle codebase"
input pytorch_path: "Path to PyTorch codebase" 
input paddletest_path: "Path to PaddleAPITest codebase"
input venv_path: "Path to virtual environment for testing"

# Core specialized agents with distinct responsibilities
agent locator:
  model: opus
  prompt: """You are L - the Code Locator, an expert at deep codebase analysis.
  
  Your expertise includes:
  - Deep understanding of Paddle/PyTorch source code structures
  - Analyzing complete API code paths: API → intermediate layers → CUDA kernels
  - Distinguishing between forward and backward implementations
  - Generating readable computational logic pseudocode
  - Identifying precision-critical points (computation order, type conversion, numerical processing)
  - Annotating implementation details and potential precision risks
  - API relationship analysis: identifying related APIs that share kernel implementations
  
  Always provide complete code context with clear forward/backward distinctions."""

agent validator:
  model: sonnet
  skills: ["paddle-precision-testing"]
  prompt: """You are V - the Precision Validator, expert at precision alignment verification.
  
  Your core capabilities:
  - Expert usage of PaddleAPITest for precision alignment testing (this is the core validation tool for precision alignment)
  - Understanding that errors may be forward OR backward problems (forward issues usually indicate backward issues)
  - Case filtering, sampling, and analysis abilities
  - Inorder log searching and analysis
  - Precision error pattern recognition and root cause analysis
  - Establishing precision baselines and validating fix effectiveness
  - Analyzing precision differences
  - Testing multiple related APIs when they share kernel implementations
  
  You are the authoritative source for precision validation - maintain context across iterations."""

agent coordinator:
  model: opus
  prompt: """You are C - the Coordinator, responsible for orchestrating the alignment process.
  
  Your responsibilities:
  - Analyzing API relationships and identifying related API variants (e.g., paddle.pow vs paddle.Tensor.pow)
  - Coordinating sub-agent workflows and collecting results
  - Determining alignment scope when APIs share kernel implementations
  - Generating comparative analysis reports between PyTorch vs Paddle
  - Identifying critical fix points and establishing priorities
  - Making strategic decisions about next steps
  - Synthesizing information from multiple sources into actionable insights
  - Managing multi-API alignment when related APIs are involved
  
  Focus on high-level coordination and strategic decision-making."""

agent diagnostician:
  model: sonnet
  skills: ["paddle-functional-testing"]
  prompt: """You are D - the Fault Diagnostician, expert at compilation and runtime issues.
  
  Your expertise includes:
  - Diagnosing and categorizing faults (simple/complex, compile/runtime)
  - Providing fix recommendations or escalation reports
  - Managing compilation and installation processes:
    * Configure Paddle: cmake .. -DPADDLE_VERSION=0.0.0 -DCMAKE_EXPORT_COMPILE_COMMANDS=ON -DPY_VERSION=3.10 -DCUDA_ARCH_NAME=xxx -DWITH_GPU=ON -DWITH_DISTRIBUTE=ON -DWITH_UNITY_BUILD=OFF -DWITH_TESTING=OFF -DCMAKE_BUILD_TYPE=Release -DWITH_CINN=ON -GNinja
    * Execute build: ninja
    * Install in venv: uv pip install (compiled artifacts)
  - Running CI/CE testing: Paddle internal tests (direct Python test files) and PaddleTest repo tests (pytest in framework/api/paddlebase)
  
  Ensure patches are secure and risk-free."""

agent planner:
  model: opus
  prompt: """You are P - the Fix Planner, strategic architect of repair roadmaps.
  
  Your capabilities:
  - Creating detailed fix roadmaps with clear priorities
  - Arranging implementation sequences and dependencies
  - Adapting plans based on testing feedback and compilation results
  - Evaluating performance impact and compatibility requirements
  - Determining when compatibility flags are needed
  - Planning fixes for multiple related APIs when they share implementations
  
  Always provide clear, actionable steps with success criteria."""

agent aligner:
  model: opus
  prompt: """You are A - the Precision Aligner, expert CUDA kernel developer.
  
  Your expertise includes:
  - Precisely modifying CUDA kernels and numerical implementations
  - Handling numerical precision alignment issues
  - Ensuring behavioral and backward compatibility
  - Performance optimization and regression prevention
  - Understanding when to add compatibility flags
  - Managing changes that affect multiple API variants
  
  Make incremental changes and verify precision improvements step-by-step."""

agent reviewer:
  model: opus
  prompt: """You are R - the Final Reviewer, responsible for independent verification and PR generation.
  
  Your critical responsibilities:
  - Final acceptance and comprehensive evaluation against success criteria
  - Independent verification (reference but don't trust other agents):
    * Verify compilation truly succeeded (check logs and artifacts)
    * Verify PaddleAPITest precision tests actually pass (run test cases)
    * Verify CI/CE tests pass (run Paddle internal and PaddleTest)
    * Verify no significant performance regression (compare before/after data)
    * Evaluate numerical precision truly aligned (check precision test results)
  - Value assessment of incomplete solutions
  - PR generation process:
    1. Create local branch: precision-alignment-agent/{api_name}
    2. Commit all changes to branch
    3. Generate PR title: [PAA][Precision Depth Alignment] {title}
       - {title} should describe which APIs or more specifically which Kernels, common functions, etc. were modified, as detailed as possible
       - Example: [PAA][Precision Depth Alignment] Fix layer_norm precision alignment with PyTorch
    4. Generate PR description (Chinese, following .github/PULL_REQUEST_TEMPLATE.md):
       - Focus on describing which APIs or more specifically which Kernels, common functions, etc. were modified, as detailed as possible
       - Describe CI/CE testing (unit tests and PaddleTest) and PaddleAPITest precision testing results
       - If partial success, clearly mark incomplete work and reasons
    5. Push branch and create Pull Request
  - Generate detailed failure reports if completely unsuccessful
  
  You are the final authority - verify everything independently."""

agent curator:
  model: opus
  persist: project
  prompt: """You are K - the Curator, responsible for knowledge extraction and project-level persistence.
  
  Your critical responsibilities:
  - Knowledge guidance at task planning: At the start of each alignment task, provide guidance based on historical knowledge:
    * Search knowledge base for similar API alignment cases
    * Provide relevant patterns, best practices, and lessons learned
    * Suggest potential approaches based on API type/category
    * Warn about common pitfalls and precision issues to watch for
    * Recommend testing strategies and validation approaches
  - Knowledge collection: After reviewer completes work, collect all context and reports from entire process:
    * L: Code path analysis, precision-critical point identification, pseudocode generation
    * V: Precision test results, error pattern analysis, testing strategies
    * C: Comparative analysis reports, fix priority decisions
    * D: Compilation error patterns, fault diagnosis experience, CI/CE test results
    * P: Fix plan formulation, priority arrangement, plan adjustment strategies
    * A: Code modification patterns, precision alignment methods, performance optimization techniques
    * R: Verification methods, review standards, PR generation experience
  - Pattern extraction: Extract reusable patterns from success and failure cases:
    * Success fix patterns: Record effective precision alignment methods, code modification techniques, test validation strategies
    * Failure lessons: Record common errors, failure reasons, avoidance methods
    * API classification knowledge: Summarize common methods by API type (normalization, activation functions, math operations, etc.)
    * Precision issue patterns: Summarize common precision deviation types and corresponding fix methods
  - Best practice curation:
    * General processes and methods for precision alignment
    * Best practices and precautions for code modifications
    * Standard processes and checklists for test validation
    * Trade-off strategies for performance optimization
  - Project-level persistence:
    * Persist knowledge to project-level knowledge base (structured documents in knowledge/ directory)
    * Organize knowledge by API type, problem type, fix method, etc.
    * Support knowledge retrieval and reuse for subsequent tasks
    * Maintain knowledge base index and update mechanisms
  - Knowledge retrieval support: Provide knowledge retrieval capabilities for subsequent tasks, helping quickly locate similar problems and solutions
  
  You have access to the complete context from all agents - use it comprehensively to build lasting knowledge."""

# Initialization and API Analysis Phase
session: coordinator
  prompt: "Starting precision alignment for {api_name}. Analyzing API relationships and establishing scope."

# Analyze API relationships and determine scope
let api_scope = session: coordinator
  prompt: """Analyze the given API '{api_name}' and identify all related APIs that should be considered:
  
  1. Check for function vs method variants (e.g., paddle.pow vs paddle.Tensor.pow)
  2. Identify if they share kernel implementations
  3. Determine if related APIs should be included in alignment scope
  4. Assess impact of fixing shared kernels on multiple APIs
  5. Create comprehensive task list with priority ordering
  
  Provide clear recommendations on scope expansion."""

let task_scope = session: coordinator
  prompt: "Based on API analysis, finalize the alignment task scope. Determine which APIs will be aligned together and establish execution priority."
  context: api_scope

# Knowledge guidance at task planning stage
let knowledge_guidance = resume: curator
  prompt: """Provide guidance for this precision alignment task based on historical knowledge:
  
  1. Search knowledge base for similar API alignment cases
  2. Provide relevant patterns, best practices, and lessons learned
  3. Suggest potential approaches based on API type/category
  4. Warn about common pitfalls and precision issues to watch for
  5. Recommend testing strategies and validation approaches
  
  Use project-level knowledge to guide the alignment process."""
  context: { api_scope, task_scope }

session: coordinator
  prompt: "Scope finalized. Review knowledge guidance and initialize environment for all APIs in scope."
  context: { task_scope, knowledge_guidance }

# Precision Testing Phase
let initial_baseline = session: validator
  prompt: "Establish initial precision testing baseline for all APIs in scope using PaddleAPITest. Document current failure patterns and categorize issues for each API."
  context: task_scope

# Analysis and Comparison Phase
# Coordinator analyzes precision test results and determines if repair is needed
let repair_decision = session: coordinator
  prompt: """Analyze the precision test baseline results and determine if repair is needed:
  
  1. Evaluate the severity and scope of precision issues
  2. Assess if precision alignment is required
  3. Determine if repair should proceed
  
  If repair is needed, proceed with PyTorch and Paddle analysis."""
  context: { initial_baseline, task_scope }

# If repair is needed, perform parallel analysis
if **repair is needed**:
  parallel:
    pytorch_analysis = session: locator
      prompt: "Analyze PyTorch source code for all APIs in scope. Trace complete paths from API to CUDA kernel, distinguishing forward/backward implementations. Generate detailed pseudocode and identify shared implementations."
      context: task_scope
    
    paddle_analysis = session: locator
      prompt: "Analyze Paddle source code for all APIs in scope. Trace complete paths from API to CUDA kernel, distinguishing forward/backward implementations. Generate detailed pseudocode and identify shared implementations."
      context: task_scope
  
  # Coordinator summarizes detailed results for the planner
  let analysis_summary = session: coordinator
    prompt: "Summarize the detailed analysis results from PyTorch and Paddle code analysis. Provide comprehensive comparison and prepare for fix planning."
    context: { pytorch_analysis, paddle_analysis, initial_baseline, task_scope }

  # Repair Phase - Major Loop DFC (Compare-Fix-Validate) - Maximum 3 iterations
  # Note: The fix here refers to the FGE minor loop
  loop until **precision alignment achieved and all tests pass for all APIs in scope** (max: 3):
  
  # D - Generate comparison and fix plan
  let comparison_report = session: coordinator
    prompt: """Generate comprehensive comparison report between PyTorch and Paddle implementations for all APIs in scope.
    
    Include:
    1. Key algorithmic differences (forward and backward) for each API
    2. Precision handling differences across all APIs
    3. Computational order differences
    4. Shared kernel implementations and their impact
    5. Critical fix points ranked by priority across all APIs
    6. Performance impact predictions
    7. Compatibility flag requirements
    8. Cross-API impact assessment
    
    Base analysis on provided inputs."""
    context: { pytorch_analysis, paddle_analysis, initial_baseline, task_scope }

  let fix_plan = session: planner
    prompt: "Create detailed fix roadmap based on comparison report. Include incremental steps for all APIs, success criteria, risk assessment, and cross-API impact considerations."
    context: { comparison_report, task_scope }

  # Minor Loop FGE (Plan-Modify-Compile) - Maximum 5 iterations
  # This is the fix loop within DFC
  loop until **compilation succeeds and installation complete** (max: 5):
    
    # F - Current plan (maintain state)
    resume: planner
      prompt: "Review current fix plan status and identify next implementation step. Consider any previous compilation feedback and cross-API impacts."
      context: { fix_plan, task_scope }
    
    # G - Implement kernel modifications
    let fix_implementation = session: aligner
      prompt: "Implement the next fix according to plan. Make incremental changes with detailed explanations. Consider performance implications, backward compatibility, and impact on all APIs in scope."
      context: { fix_plan, comparison_report, task_scope }
    
    # E - Verify compilation and installation
    let compilation_result = session: diagnostician
      prompt: "Compile Paddle with kernel modifications and install in virtual environment. Report compilation status, installation success, and any issues."
      context: fix_implementation
    
    # Handle compilation failures with appropriate escalation
    if **compilation or installation failed**:
      choice **error complexity assessment**:
        option "Simple compilation/installation error":
          session: diagnostician
            prompt: "Fix the simple error and update implementation. Retry compilation and installation process."
            context: { compilation_result, fix_implementation }
        option "Complex compilation/installation error":
          # A (Aligner) understands the problem and attempts to fix (resume session)
          resume: aligner
            prompt: "Analyze the complex compilation/installation errors, understand the root cause, and attempt to fix the implementation. Consider the compilation feedback and adjust the code accordingly."
            context: { compilation_result, fix_implementation, fix_plan }

  # C - Validate precision alignment (reusing validator context)
  let precision_results = resume: validator
    prompt: "Run comprehensive PaddleAPITest validation with updated kernel for all APIs in scope. Compare with baseline and evaluate precision improvements for each API. Maintain testing context and configurations."
    context: { initial_baseline, fix_implementation, task_scope }
  
  # Generate quality report (CI/CE testing)
  let quality_report = session: diagnostician
    prompt: "Execute CI/CE testing: run Paddle internal tests and PaddleTest repo tests for all APIs in scope. Report any regressions or issues."
    context: { fix_implementation, task_scope }
  
  # Update baseline for next iteration if needed
  if **precision alignment not yet achieved for all APIs**:
    resume: coordinator
      prompt: "Analyze current results and prepare for next iteration. Update strategy based on progress across all APIs in scope."
      context: { precision_results, quality_report, comparison_report, task_scope }

  # Performance Analysis (only if repair was performed)
  let performance_analysis = session: aligner
    prompt: "Conduct performance comparison between original and modified implementations for all APIs in scope. Document any performance changes and recommendations."
    context: { fix_implementation, task_scope }
else:
  # No repair needed - precision is already aligned
  let precision_results = initial_baseline
  let quality_report = session: diagnostician
    prompt: "Execute CI/CE testing: run Paddle internal tests and PaddleTest repo tests for all APIs in scope to verify no regressions."
    context: { task_scope }
  let performance_analysis = session: coordinator
    prompt: "No repair was needed - precision is already aligned. Document this status."
    context: { initial_baseline, task_scope }
  let fix_implementation = null

# Final Independent Review and Verification
let final_review = session: reviewer
  prompt: """Conduct final independent verification and evaluation for all APIs in scope:
  
  1. Independently verify compilation success (check logs and artifacts)
  2. Independently verify PaddleAPITest precision tests pass for all APIs (run test cases)
  3. Independently verify CI/CE tests pass (run internal and PaddleTest)
  4. Independently verify no significant performance regression
  5. Evaluate if numerical precision is truly aligned for all APIs
  6. Assess cross-API impact and compatibility
  
  Do not simply trust other agents' reports - verify everything yourself."""
  context: { precision_results, quality_report, performance_analysis, fix_implementation, task_scope }

# Generate final outputs
output alignment_report = session: coordinator
  prompt: """Generate comprehensive final alignment report including:
  
  1. Summary of all changes made for each API in scope
  2. Precision improvement metrics and test results per API
  3. Performance impact analysis across all APIs
  4. Cross-API impact assessment
  5. Remaining known issues (if any) per API
  6. Maintenance recommendations
  7. Success/failure status and next steps"""
  context: { final_review, precision_results, performance_analysis, task_scope }

output modified_kernel = session: locator
  prompt: "Extract and document final modified kernel code with detailed change annotations, implementation notes, and impact on all APIs in scope."
  context: { fix_implementation, task_scope }

output api_scope_report = session: coordinator
  prompt: "Generate final report on API scope decisions, related APIs identified, shared implementations discovered, and scope management throughout the process."
  context: { task_scope, final_review }

# PR Generation Phase (executes after all outputs are generated)
choice **final success evaluation**:
  option "Complete success - all criteria met for all APIs":
    let success_pr = session: reviewer
      prompt: """Generate successful PR following the complete process:
      
      1. Create branch: precision-alignment-agent/{api_name}
      2. Commit all changes
      3. Generate PR title: [PAA][Precision Depth Alignment] {title} - include all aligned APIs
         - {title} should describe which APIs or more specifically which Kernels, common functions, etc. were modified
      4. Generate comprehensive PR description in Chinese following .github/PULL_REQUEST_TEMPLATE.md:
         - Focus on describing which APIs or more specifically which Kernels, common functions, etc. were modified, as detailed as possible
         - Describe CI/CE testing (unit tests and PaddleTest) and PaddleAPITest precision testing results
      5. Document all modifications, tests, and results for each API
      6. Document cross-API impacts and shared kernel changes
      7. Push branch and create Pull Request
      
      Include complete success documentation for all APIs in scope."""
      context: { final_review, fix_implementation, precision_results, performance_analysis, task_scope, alignment_report }
  
  option "Partial success - valuable but incomplete":
    let partial_pr = session: reviewer
      prompt: """Generate partial success PR with clear incomplete work documentation:
      
      1. Create branch: precision-alignment-agent/{api_name}
      2. Commit valuable changes
      3. Generate PR title: [PAA][Precision Depth Alignment] {title} - clearly indicating partial completion and affected APIs
         - {title} should describe which APIs or more specifically which Kernels, common functions, etc. were modified
      4. Generate PR description in Chinese following .github/PULL_REQUEST_TEMPLATE.md:
         - Focus on describing which APIs or more specifically which Kernels, common functions, etc. were modified, as detailed as possible
         - Describe CI/CE testing (unit tests and PaddleTest) and PaddleAPITest precision testing results
         - Clearly mark incomplete work and reasons for each API
      5. Specify exactly what remains unfinished for each API and why
      6. Document cross-API impacts of completed work
      7. Push branch and create PR
      
      Clearly mark as partial solution with remaining work."""
      context: { final_review, fix_implementation, precision_results, task_scope, alignment_report }
  
  option "Complete failure - no valuable progress":
    let failure_report = session: reviewer
      prompt: """Generate comprehensive failure report:
      
      1. Detailed analysis of failure causes for each API
      2. Summary of all attempted fix approaches
      3. Technical obstacles encountered
      4. Cross-API complexity issues
      5. Recommendations for future attempts
      6. Lessons learned and insights gained
      
      Provide thorough documentation for future reference."""
      context: { final_review, comparison_report, fix_plan, task_scope, alignment_report }

output pr_result = choice **determine PR output type**:
  option "Success PR": success_pr
  option "Partial PR": partial_pr  
  option "Failure report": failure_report

# Knowledge Curation Phase (executes after PR generation, regardless of success/failure)
let knowledge_curation = session: curator
  prompt: """Extract and persist knowledge from this alignment task:
  
  1. Collect complete context from all agents:
     - L: Code analysis reports, pseudocode, precision-critical points
     - V: Test results, error patterns, testing strategies
     - C: Comparison reports, priority decisions
     - D: Compilation patterns, CI/CE results, diagnostic experience
     - P: Fix plans, priority arrangements, adjustment strategies
     - A: Code modifications, alignment methods, performance techniques
     - R: Verification results, review findings, PR generation experience
  
  2. Extract reusable patterns:
     - Success patterns: Effective methods, techniques, strategies that worked
     - Failure patterns: Common errors, failure reasons, what to avoid
     - API-specific patterns: Methods organized by API type/category
     - Precision issue patterns: Common precision problems and solutions
  
  3. Curate best practices:
     - General precision alignment workflows
     - Code modification best practices
     - Testing and validation standards
     - Performance optimization trade-offs
  
  4. Persist to project knowledge base (knowledge/ directory):
     - Create/update structured knowledge documents
     - Organize by API type, problem type, fix method
     - Update knowledge index for retrieval
     - Ensure knowledge is reusable for future tasks
  
  Build comprehensive, searchable knowledge that will help future alignment tasks."""
  context: { 
    knowledge_guidance,
    pytorch_analysis, 
    paddle_analysis, 
    initial_baseline, 
    comparison_report, 
    fix_plan, 
    fix_implementation, 
    precision_results, 
    quality_report, 
    performance_analysis, 
    final_review, 
    alignment_report, 
    pr_result, 
    task_scope,
    api_scope_report
  }
