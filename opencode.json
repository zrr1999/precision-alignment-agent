{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "external_directory": {
      "*": "deny",
      "/workspace/*": "allow"
    }
  },
  "agent": {
    "precision-alignment": {
      "mode": "primary",
      "model": "github-copilot/claude-opus-4.6",
      "temperature": 0.2,
      "prompt": "{file:./precision-alignment.md}",
      "skills": [
        "paa-just-workflow",
        "paa-knowledge-curation"
      ],
      "tools": {
        "read": true,
        "glob": true,
        "grep": true,
        "bash": true,
        "write": true,
        "edit": false,
        "webfetch": true
      },
      "permission": {
        "bash": {
          "*": "deny",
          "ls*": "allow",
          "cat*": "allow",
          "head*": "allow",
          "tail*": "allow",
          "grep*": "allow",
          "wc*": "allow",
          "pwd": "allow",
          "date*": "allow",
          "echo*": "allow",
          "git status*": "allow",
          "git log*": "allow",
          "git diff*": "allow",
          "git rev-parse*": "allow",
          "git branch*": "allow"
        },
        "task": {
          "*": "deny",
          "explorer": "allow",
          "learner": "allow",
          "aligner": "allow",
          "diagnostician": "allow",
          "validator": "allow",
          "reviewer": "allow"
        },
        "question": "allow"
      }
    },
    "precision-analysis": {
      "mode": "primary",
      "model": "github-copilot/claude-opus-4.6",
      "temperature": 0.2,
      "prompt": "{file:./precision-analysis.md}",
      "skills": [
        "paa-just-workflow",
        "paa-knowledge-curation"
      ],
      "tools": {
        "read": true,
        "glob": true,
        "grep": true,
        "bash": true,
        "write": false,
        "edit": false,
        "webfetch": true
      },
      "permission": {
        "bash": {
          "*": "deny",
          "ls*": "allow",
          "cat*": "allow",
          "head*": "allow",
          "tail*": "allow",
          "grep*": "allow",
          "wc*": "allow",
          "pwd": "allow",
          "date*": "allow",
          "echo*": "allow",
          "git status*": "allow",
          "git log*": "allow",
          "git diff*": "allow",
          "git rev-parse*": "allow",
          "git branch*": "allow"
        },
        "task": {
          "*": "deny",
          "explorer": "allow",
          "learner": "allow"
        },
        "question": "allow"
      }
    }
  }
}
