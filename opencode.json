{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "external_directory": {
      "*": "deny",
      "/workspace/*": "allow"
    }
  },
  "agent": {
    "precision-alignment": {
      "mode": "primary",
      "model": "github-copilot/gpt-5.2-codex",
      "temperature": 0.2,
      "prompt": "{file:./precision-alignment.md}",
      "tools": {
        "read": true,
        "glob": true,
        "bash": false,
        "write": false,
        "edit": false
      },
      "permission": {
        "task": {
          "*": "deny",
          "planner": "allow",
          "validator": "allow",
          "reviewer": "allow"
        },
        "question": "allow"
      },
      "skills": {}
    }
  }
}
