{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "precision-alignment": {
      "mode": "primary",
      "model": "github-copilot/claude-sonnet-4.5",
      "temperature": 0.2,
      "prompt": "{file:./precision-alignment.md}",
      "tools": {
        "read": true,
        "bash": true,
        "write": false,
        "edit": false
      },
      "permission": {
        "task": {
          "*": "deny",
          "planner": "allow",
          "validator": "allow",
          "reviewer": "allow"
        },
        "question": "allow",
        "bash": {
          "*": "deny",
          "ls*": "allow",
          "cd*": "allow",
          "pwd": "allow",
          "grep*": "allow",
          "cat*": "allow",
          "head*": "allow",
          "tail*": "allow",
          "wc*": "allow",
          "which*": "allow",
          "echo*": "allow",
          "printf*": "allow",
          "true": "allow",
          "false": "allow",
          "git*": "allow"
        }
      }
    }
  }
}